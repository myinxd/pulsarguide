---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Pulsar Guide" href="/rss.xml" />

    <!-- KaTeX CSS for LaTeX rendering -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLhoTIBq4sF+NpDfUHSRhZ7L3I5f3W0uP1rC34z"
      crossorigin="anonymous"
    />

    <!-- Google Fonts: Inter + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} | Pulsar Guide` : 'Pulsar Guide'}</title>
    <meta name="description" content={description || 'A technical blog about autonomous driving, built by a radio astronomer turned self-driving engineer.'} />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-container">
        <a href="/" class="logo">
          <span class="logo-text">
            <span class="logo-name">Pulsar</span>
            <span class="logo-sub">Guide</span>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/blog">文章</a>
          <a href="/paper-notes">论文笔记</a>
          <a href="/life">生活</a>
          <a href="/about">关于</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-content">
        <p>© {new Date().getFullYear()} Pulsar Guide · 星导</p>
        <p class="footer-tagline">从脉冲星到自动驾驶 · 一个天文人的技术漫游</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f7f8fa;
    --bg-card: #ffffff;
    --text-primary: #1a1a2e;
    --text-secondary: #4a5568;
    --text-muted: #94a3b8;
    --accent-1: #7c3aed;
    --accent-2: #06b6d4;
    --accent-3: #10b981;
    --border: #e2e8f0;
    --max-width: 1000px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  code, pre {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  a {
    color: var(--accent-2);
    text-decoration: none;
    transition: color 0.2s;
  }
  a:hover {
    color: var(--accent-3);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(255, 255, 255, 0.9);
    border-bottom: 1px solid var(--border);
  }

  .nav-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-text {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .logo-name {
    font-size: 1.1rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.01em;
  }

  .logo-sub {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .nav-container {
      padding: 0 1rem;
      height: 56px;
    }
    .nav-links {
      gap: 1rem;
    }
    .nav-links a {
      font-size: 0.8rem;
    }
    .logo-name {
      font-size: 1rem;
    }
    .logo-sub {
      font-size: 0.7rem;
    }
    main {
      padding: 0 1rem;
    }
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    min-height: calc(100vh - 160px);
  }

  h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  h1 { font-size: 2.2rem; }
  h2 { font-size: 1.6rem; }
  h3 { font-size: 1.25rem; }

  p {
    margin-bottom: 1.2rem;
  }

  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
  }

  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .footer-tagline {
    margin-top: 0.25rem;
    font-style: italic;
  }
</style>
