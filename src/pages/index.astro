---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="hero">
    <div class="hero-badge">
      <span class="badge-pulse"></span>
      从射电望远镜到自动驾驶
    </div>
    <h1 class="hero-title">
      <span class="gradient-text">Pulsar Guide</span>
      <span class="hero-sub">星导</span>
    </h1>
    <p class="hero-desc">
      一个前射电天文学者的自动驾驶技术博客。<br />
      记录论文阅读、工程实践，以及对感知与决策的思考。
    </p>
    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary">浏览文章</a>
      <a href="/about" class="btn btn-outline">关于我</a>
    </div>
  </section>

  <section class="features">
    <div class="feature-card">
      <div class="feature-icon">📄</div>
      <h3>论文笔记</h3>
      <p>自动驾驶领域前沿论文的精读与思考。</p>
      <a href="/paper-notes">查看笔记 →</a>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔧</div>
      <h3>工程实践</h3>
      <p>从实际项目积累的自动驾驶算法与系统经验。</p>
      <a href="/blog">阅读文章 →</a>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🛣️</div>
      <h3>导航选道</h3>
      <p>行为规划、运动预测与决策算法深度解析。</p>
      <a href="/blog">深入了解 →</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 5rem 0 4rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(124, 58, 237, 0.12);
    border: 1px solid rgba(124, 58, 237, 0.3);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    color: var(--accent-1);
    margin-bottom: 1.5rem;
  }

  .badge-pulse {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-1);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    margin-bottom: 1.5rem;
  }

  .gradient-text {
    font-size: 3.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2), var(--accent-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 1.2rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .hero-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 550px;
    margin: 0 auto 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.6rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    color: white;
    border: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3);
  }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-primary);
  }
  .btn-outline:hover {
    border-color: var(--accent-2);
    color: var(--accent-2);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding: 2rem 0 4rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.8rem;
    transition: all 0.25s;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    border-color: rgba(6, 182, 212, 0.3);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    margin-top: 0;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .feature-card a {
    font-size: 0.9rem;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .features {
      grid-template-columns: 1fr;
    }
    .gradient-text {
      font-size: 2.2rem;
    }
    .hero {
      padding: 3rem 0 2rem;
    }
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
