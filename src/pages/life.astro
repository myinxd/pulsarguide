---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .filter((post) => post.data.tags?.includes('生活') || post.data.tags?.includes('AI工具'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="生活" description="程序员的非技术日常：AI 工具、生活技巧与跨界思考">
  <section class="page-header">
    <h1>🌿 生活</h1>
    <p>程序员的非技术日常 · AI 工具实战 · 跨界小思考</p>
  </section>

  <section class="intro-card">
    <p>
      技术文章写累了，来这里歇歇脚。这里记录的是我作为一个工程师在日常生活里折腾的小玩意、
      薅到的 AI 羊毛、以及那些"写代码写多了看什么都想优化"的瞬间。
    </p>
    <p>
      不严肃，但认真。
    </p>
  </section>

  {posts.length > 0 ? (
    <section class="post-list">
      <h2 class="section-label">📌 最近更新</h2>
      {
        posts.map((post) => (
          <article class="post-card">
            <a href={`/blog/posts/${post.id}`} class="post-link">
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <div class="post-tags">
                  {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
            </a>
          </article>
        ))
      }
    </section>
  ) : (
    <div class="empty-state">
      <p>🌱 生活专栏正在开垦中，第一篇马上就来……</p>
    </div>
  )}
</Layout>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }
  .page-header h1 { margin: 0; font-size: 1.8rem; }
  .page-header p { color: var(--text-secondary); margin-top: 0.5rem; }

  .intro-card {
    background: rgba(124, 58, 237, 0.06);
    border: 1px solid rgba(124, 58, 237, 0.15);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin-bottom: 2.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
  }
  .intro-card p:last-child { margin-bottom: 0; color: var(--text-muted); font-style: italic; }

  .section-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .post-list { padding-bottom: 4rem; }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 0.75rem;
    transition: all 0.2s;
  }
  .post-card:hover {
    border-color: rgba(124, 58, 237, 0.3);
    background: rgba(26, 26, 37, 0.8);
  }
  .post-link { display: block; color: inherit; text-decoration: none; }

  .post-meta {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 0.5rem; font-size: 0.85rem; color: var(--text-muted);
  }
  .post-tags { display: flex; gap: 0.4rem; }
  .tag {
    background: rgba(124, 58, 237, 0.1);
    border: 1px solid rgba(124, 58, 237, 0.2);
    padding: 0.15rem 0.5rem; border-radius: 4px;
    font-size: 0.75rem; color: var(--accent-1);
  }
  .post-title { margin: 0 0 0.5rem; font-size: 1.2rem; color: var(--text-primary); }
  .post-card:hover .post-title { color: var(--accent-1); }
  .post-desc { color: var(--text-secondary); font-size: 0.9rem; margin: 0; }

  .empty-state {
    text-align: center; padding: 4rem 0;
    color: var(--text-muted);
  }
</style>
