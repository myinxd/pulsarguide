---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('paperNotes'))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="论文笔记" description="自动驾驶论文精读与思考">
  <section class="page-header">
    <h1>📄 论文笔记</h1>
    <p>自动驾驶领域前沿论文的精读、总结与思考</p>
  </section>

  <section class="post-list">
    {
      notes.length > 0 ? (
        notes.map((note) => (
          <article class="post-card">
            <a href={`/paper-notes/notes/${note.slug}`} class="post-link">
              <div class="post-meta">
                <time datetime={note.data.pubDate.toISOString()}>
                  {note.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <div class="post-tags">
                  {note.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <h2 class="post-title">{note.data.title}</h2>
              <p class="post-desc">{note.data.description}</p>
              {note.data.paperUrl && <span class="paper-link">🔗 原论文 →</span>}
            </a>
          </article>
        ))
      ) : (
        <div class="empty-state">
          <p>📚 论文笔记正在整理中，敬请期待……</p>
        </div>
      )
    }
  </section>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
  }
  .page-header h1 {
    margin: 0;
    font-size: 1.8rem;
  }
  .page-header p {
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 4rem;
  }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: all 0.2s;
  }
  .post-card:hover {
    border-color: rgba(6, 182, 212, 0.3);
    background: rgba(26, 26, 37, 0.8);
  }

  .post-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
  }

  .tag {
    background: rgba(124, 58, 237, 0.1);
    border: 1px solid rgba(124, 58, 237, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--accent-1);
  }

  .post-title {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    color: var(--text-primary);
    transition: color 0.2s;
  }
  .post-card:hover .post-title {
    color: var(--accent-2);
  }

  .post-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin: 0 0 0.5rem;
    line-height: 1.5;
  }

  .paper-link {
    font-size: 0.85rem;
    color: var(--accent-3);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-muted);
  }
</style>
